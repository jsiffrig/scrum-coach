# =============================================================================
# SCRUM Coach Assistant — Environment variables template
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# --- App ---
APP_ENV=development                 # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
APP_SECRET_KEY=change-me-to-a-long-random-string

# --- Database (PostgreSQL + pgvector) ---
DB_URL=postgresql+psycopg://coach:coach@localhost:5432/scrum_coach
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- LLM provider ---
# Options: mistral | anthropic | openai (all EU residency required for prod)
LLM_PROVIDER=mistral
LLM_MODEL=mistral-large-latest
LLM_API_KEY=

# Embeddings (can differ from LLM provider)
EMBED_PROVIDER=mistral
EMBED_MODEL=mistral-embed
EMBED_API_KEY=

# --- Vector store (pgvector default; Qdrant optional) ---
VECTOR_STORE=pgvector               # pgvector | qdrant
QDRANT_URL=
QDRANT_API_KEY=

# --- Object storage (Scaleway S3-compatible) ---
S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
S3_REGION=fr-par
S3_BUCKET=scrum-coach-assistant-dev
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Auth (Clerk or self-host JWT) ---
AUTH_PROVIDER=clerk                 # clerk | jwt
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080            # 7 days

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_FREE=
STRIPE_PRICE_ID_COACH=

# --- Email (Brevo) ---
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@scrum-rugby.fr
BREVO_SENDER_NAME=SCRUM Coach Assistant

# --- Telemetry / observability (optional) ---
SENTRY_DSN=
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
